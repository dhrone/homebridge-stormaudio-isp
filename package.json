{
  "name": "homebridge-stormaudio-isp",
  "displayName": "StormAudio ISP",
  "version": "1.0.0",
  "description": "A Homebridge plugin for controlling StormAudio ISP processors via Apple HomeKit",
  "author": "dhrone",
  "license": "Apache-2.0",
  "homepage": "https://github.com/dhrone/homebridge-stormaudio-isp#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/dhrone/homebridge-stormaudio-isp.git"
  },
  "bugs": {
    "url": "https://github.com/dhrone/homebridge-stormaudio-isp/issues"
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "stormaudio",
    "homekit"
  ],
  "main": "dist/index.js",
  "files": [
    "dist/",
    "config.schema.json",
    "homebridge-ui/",
    "images/hero.png",
    "images/Room View.png",
    "images/Theater Detail Tile.png",
    "images/StormAudio and Preset Room View.png",
    "images/Preset Detail.png",
    "images/StormAudio_Presets_Zone2_Room.png",
    "images/Zone2 Detail.png",
    "images/Room with Trigger.png",
    "images/Trigger Detail.png",
    "images/New Automation.png",
    "images/Automation Trigger Selected.png",
    "images/Automation Triggers Amp Power Closed.png",
    "docs/StormAudio Remote UI Screenshot.png",
    "LICENSE",
    "CHANGELOG.md",
    "USAGE.md"
  ],
  "customUiPath": "homebridge-ui",
  "engines": {
    "node": ">=20.0.0",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "lint": "eslint src/ test/",
    "lint:prettier": "prettier --check .",
    "format": "prettier --write .",
    "prepublishOnly": "npm run lint && npm run build",
    "watch": "npm run build && npm link && nodemon",
    "test": "vitest run",
    "test:hardware": "npx ts-node test/hardware/run.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "homebridge": "^1.11.2",
    "nodemon": "^3.1.11",
    "prettier": "^3.0.0",
    "rimraf": "^6.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.2.1"
  }
}
